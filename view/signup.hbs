<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIGN UP</title>
    <!-- Google Fonts for crisp typography -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/signup.css">
</head>
<body>
    <!-- Animated background geometric blocks -->
    <div class="bg-circle circle-one"></div>
    <div class="bg-circle circle-two"></div>

    <div id="main">

        <div id="header">
            <div class="logo">STUDENT<span>PORTAL</span></div>
            <h2 class="static-title">SIGN UP</h2>
            <div class="box">
                <a href="/login" class="back-link">Back</a>
            </div>
        </div>

        <div id="fakeheader"></div>

        <div id="page">
             <form action="/student/signup" method="POST" id="signupForm">
                <div class="form-header">
                    <h3>Create Account</h3>
                    <p>Please fill your academic details</p>
                </div>

                <input name="prn" type="text" placeholder="PRN" required autocomplete="off">
                <input name="name" type="text" placeholder="Name" required autocomplete="off">
                <input name="year" type="number" min="1" max="4" placeholder="Studying Year (e.g., 1, 2, 3, 4)" required>
                <input name="division" type="text" placeholder="Division" required autocomplete="off">
                <input name="password" type="password" placeholder="Password" required>
                
                <button type="submit" class="ripple-btn">Signup</button>
                
                {{#if message}}
                    <div class="error-container">
                        <p class="error-msg">{{message}}</p>
                    </div>
                {{/if}}

                <div class="divider">
                    <span>or</span>
                </div>

                <a href="/student/studentlog" class="login-redirect-btn ripple-btn">Student Login</a>  
             </form>
        </div>
        
    </div>

    <!-- Smooth Page Interactions Script -->
    <script src="/js/signup.js"></script>
</body>
</html>