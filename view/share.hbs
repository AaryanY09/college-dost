<!DOCTYPE html>
<html>
<head>
    <title>Share Content</title>
    <link rel="stylesheet" href="/css/shareContent.css">
</head>
<body>

<header>
    <div class="logo">CollegeDost</div>
    <h2 class="share-title">Share Content</h2>
    <a href="/mentor/mentorDash" class="back-btn">← Back</a>
</header>

<div class="chat-container">

    <div class="chat-box" id="chatBox">
        <!-- Messages -->
        <div class="message received">Hello Mentor 👋</div>
        <div class="message sent">Hi! Sharing resources now.</div>
    </div>

    <div class="input-area">
    <input class="file-input" type="file">
    <input class="text-input" type="text" placeholder="Write announcement...">
    <button class="send-btn">Post</button>
    </div>

</div>

</body>
</html>