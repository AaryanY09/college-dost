<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete student</title>
    <link rel="stylesheet" href="/css/deletemen.css">
</head>
<body>
    <div id="main">

        <div id="header">
            <div class="logo">College Dost</div>
            <h2>Delete mentor</h2>
            <div class="box">
                <a href="/admin/adminP" class="btn btn-secondary">Back to dashboard</a>
             </div>
        </div>

        <div id="fakeheader"></div>

        <div id="page">
             <form action="/admin/deletemen" method="POST">
                            <input name="prn"  placeholder="PRN">
                            <input name="name" placeholder="Name">
                           
                    <button type="submit">Delete mentor</button>
                     {{#if message}}
                            <p style="color:red;">{{message}}</p>
                     {{/if}}


              </form>
                   
        </div>
        
    </div>

    
</body>
</html>


