<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADMIN</title>
    <!-- Google Fonts for premium typography -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/adminlog.css">
</head>
<body>
    <!-- Smoothly drifting structural background shapes -->
    <div class="bg-circle circle-one"></div>
    <div class="bg-circle circle-two"></div>

    <div id="main">

        <div id="header">
            <div class="logo">ADMIN<span>CORE</span></div>
            <h2 class="static-title">ADMIN LOGIN</h2>
            <div class="box">
                <a href="/login" class="back-link">Back</a>
            </div>
        </div>

        <div id="fakeheader"></div>

        <div id="page">
            <form action="/admin/adminlog" method="POST" target="_blank" id="adminLoginForm">
                <div class="form-header">
                    <h3>System Control</h3>
                    <p>Enter administrator credentials</p>
                </div>

                <div class="input-group">
                    <input name="username" type="text" placeholder="Admin Username" required autocomplete="off">
                </div>
                
                <div class="input-group">
                    <input name="password" type="password" placeholder="Password" required>
                </div>

                <button type="submit" class="ripple-btn">Login</button>

                {{#if message}}
                    <div class="error-container">
                        <p class="error-msg">{{message}}</p>
                    </div>
                {{/if}}
            </form>
        </div>
        
    </div>

    <!-- Client Interactive JS -->
    <script src="/js/adminlog.js"></script>
</body>
</html>