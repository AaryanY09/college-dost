<!DOCTYPE html>
<html>
<head>
    <title>Chat</title>
    <link rel="stylesheet" href="/css/chat.css">
</head>
<body>

<header class="navbar">
    <div class="logo">CollegeDost</div>
    <h2 class="title">Chat</h2>
    <a href="/mentor/mentorDash" class="back-btn">← Back</a>
</header>

<div class="chat-container">

    <div class="chat-box">
        <div class="message received">Sir I need help</div>
        <div class="message sent">Sure, tell me 👍</div>
    </div>

    <div class="input-area">
        <input class="chat-input" type="text" placeholder="Type message...">
        <button class="send-btn">Send</button>
    </div>

</div>

</div>

</body>
</html>