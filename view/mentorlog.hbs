<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MENTOR LOG IN</title>
    <link rel="stylesheet" href="/css/mentorlog.css">
</head>
<body>
    <div id="main">

        <div id="header">
            <div class="logo">LOGO</div>
            <h2>MENTOR LOGIN</h2>
            <div class="box">
                <a href="/login" class="btn btn-secondary">back</a>
            </div>
        </div>

        <div id="fakeheader"></div>

        <div id="page">
                <form action="/mentor/mentorlog" method="POST" target="_blank">
                     <input  name="prn" placeholder="Enter PRN" required><br><br>
                     <input type="password" name="password" placeholder="Enter Password" required><br><br>
                     <button type="submit">Login</button>
                      {{#if message}}
                            <p style="color:red;">{{message}}</p>
                     {{/if}}
                 </form>

        </div>
        
    </div>

    
</body>
</html>