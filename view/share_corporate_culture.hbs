<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Share Corporate Culture</title>
    <link rel="stylesheet" href="/css/corporate.css">
</head>
<body>

<!-- Navbar -->
<div class="navbar">
    <div class="logo">CollegeDost</div>

    <h2 class="title">Announcement</h2>

    <a href="/alumni/alumnidash" class="back-btn">← Back</a>
</div>

<!-- Intro -->
<div class="intro">
    <h1>Share Your Experience 💼</h1>
    <p>Help students understand real corporate life, culture, and work environment.</p>
</div>

<!-- Form -->
<div class="form-container">
    <h3>Create Post</h3>

    <input type="text" placeholder="Enter Title">

    <textarea placeholder="Describe corporate culture, environment, behavior..."></textarea>

    <input type="file">

    <button class="btn">Post</button>
</div>

<!-- Posts Section -->
<div class="posts">

    <div class="post-card">
        <h3>Work Culture at Google</h3>
        <p>Very flexible working hours, supportive team, focus on innovation.</p>
        <span>- Rahul Sharma</span>
    </div>

    <div class="post-card">
        <h3>Startup Environment</h3>
        <p>Fast-paced, high pressure but great learning and ownership.</p>
        <span>- Priya Verma</span>
    </div>

</div>

</body>
</html>